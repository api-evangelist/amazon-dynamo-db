  "info": {
    "_postman_id": "7f049f56-c5d3-4adf-810d-08a39ac3ff9c",
    "name": "Amazon DynamoDB API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Amazon DynamoDB low-level HTTPS JSON API for managing tables and indexes,\ncreating, reading, updating, and deleting items, querying and scanning\ntables, performing transactions, and processing stream records.\nAll requests use HTTP POST against the regional endpoint with an\nX-Amz-Target header indicating the action, JSON body payload, and\nAWS Signature Version 4 (SigV4) signed Authorization header.\n\n\nContact Support:\n Name: Amazon Web Services",
      "type": "text/plain"
    }
  }
